generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id            String       @id @default(uuid())
  jobId         String       @unique
  totalLogs     Int          @default(0)
  findingsCount Int          @default(0)
  actionsCount  Int          @default(0)
  createdAt     DateTime     @default(now())
  completedAt   DateTime?
  status        JobStatus    @default(PENDING)
  windowFrom    BigInt
  windowTo      BigInt
  actions       Action[]
  domainStats   DomainStat[]
  findings      Finding[]
  report        Report?
}

model Finding {
  id              String   @id @default(uuid())
  jobId           String
  findingId       String
  summary         String
  offender        Json
  classification  String
  confidence      Float
  context         Json
  createdAt       DateTime @default(now())
  evidenceSamples String[]
  metrics         Json
  timeWindowFrom  BigInt
  timeWindowTo    BigInt
  domain          Domain
  severity        Severity
  actions         Action[]
  job             Job      @relation(fields: [jobId], references: [jobId])
}

model Action {
  id          String       @id @default(uuid())
  jobId       String
  createdAt   DateTime     @default(now())
  actionType  ActionType
  completedAt DateTime?
  description String
  domain      Domain
  findingId   String?
  status      ActionStatus @default(PENDING)
  finding     Finding?     @relation(fields: [findingId], references: [id])
  job         Job          @relation(fields: [jobId], references: [jobId])
}

model Report {
  id          String   @id @default(uuid())
  jobId       String   @unique
  jsonReport  Json
  humanReport String
  createdAt   DateTime @default(now())
  job         Job      @relation(fields: [jobId], references: [jobId])
}

model DomainStat {
  id            String @id @default(uuid())
  jobId         String
  domain        Domain
  logsProcessed Int    @default(0)
  findingsCount Int    @default(0)
  actionsCount  Int    @default(0)
  job           Job    @relation(fields: [jobId], references: [jobId])

  @@unique([jobId, domain])
}

model GlobalStat {
  id            String   @id @default("singleton")
  totalJobs     Int      @default(0)
  totalLogs     Int      @default(0)
  totalFindings Int      @default(0)
  totalActions  Int      @default(0)
  lastUpdated   DateTime @default(now())
}

enum JobStatus {
  PENDING
  FETCHING
  ANALYZING
  REMEDIATING
  COMPLETED
  ERROR
}

enum ActionStatus {
  PENDING
  IN_PROGRESS
  DONE
  FAILED
}

enum Domain {
  http
  infra
  auth
}

enum Severity {
  critical
  high
  medium
  low
}

enum ActionType {
  block_ip
  rate_limit
  alert_soc
  manual_review
}
